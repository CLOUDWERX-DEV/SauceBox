{
  "manifest_version": 3,
  "name": "LocalFap Companion",
  "version": "1.0.0",
  "description": "Send videos directly to your LocalFap desktop app.",
  "permissions": ["contextMenus"],
  "host_permissions": ["http://127.0.0.1:13337/"],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
